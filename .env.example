# ─── Backend API ─────────────────────────────────────────────────────────────
BACKEND_URL=https://api.thun.ai
BACKEND_PORT=3000

# ─── Google Gemini (primary LLM + VLM) ───────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ─── Google Maps (navigation & route scoring) ────────────────────────────────
# Same key can be used if Maps API is enabled in your Google Cloud project
GOOGLE_MAPS_API_KEY=AIza...

# ─── Anthropic (Claude — secondary LLM fallback) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenAI (tertiary LLM fallback) ──────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Firebase ────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=thunai-prod
FIREBASE_SERVICE_ACCOUNT_JSON=/run/secrets/firebase_sa.json

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://thunai:password@localhost:5432/thunai

# ─── Sarvam AI (optional TTS — Indian languages) ─────────────────────────────
SARVAM_API_KEY=...
SARVAM_API_URL=https://api.sarvam.ai/text-to-speech

# ─── ElevenLabs (optional TTS — premium voice) ───────────────────────────────
ELEVENLABS_API_KEY=...

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=7d

# ─── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
