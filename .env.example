# ─── Backend API ─────────────────────────────────────────────────────────────
BACKEND_URL=https://api.thun.ai
BACKEND_PORT=3000

# ─── Anthropic (Claude) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenAI (fallback) ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Firebase ────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=thunai-prod
FIREBASE_SERVICE_ACCOUNT_JSON=/run/secrets/firebase_sa.json

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://thunai:password@localhost:5432/thunai

# ─── Google Maps (route scoring) ─────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...

# ─── Sarvam AI (TTS) ─────────────────────────────────────────────────────────
SARVAM_API_KEY=...
SARVAM_API_URL=https://api.sarvam.ai/text-to-speech

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=7d

# ─── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
