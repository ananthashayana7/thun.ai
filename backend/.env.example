# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
STRICT_STARTUP_VALIDATION=false

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://thunai:password@localhost:5432/thunai
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000

# ─── Firebase Admin ──────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=thunai-prod
FIREBASE_SERVICE_ACCOUNT_JSON=/run/secrets/firebase_sa.json

# ─── LLM Providers ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
LLM_TIMEOUT_MS=30000

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_EXPIRY=7d
PRIVACY_CONSENT_VERSION=2026-04-11

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ─── Google Maps (accident zone scoring) ─────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://thun.ai

# â”€â”€â”€ Observability â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_TRACES_SAMPLE_RATE=0.1
