{
  "name": "thun-ai",
  "version": "1.0.0",
  "private": true,
  "description": "thun.ai – AI-powered In-Vehicle Intelligence System (IVIS)",
  "workspaces": [
    "mobile",
    "backend"
  ],
  "scripts": {
